{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Loom Desktop",
  "version": "0.1.0",
  "identifier": "com.sfw.loom.desktop",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Loom Desktop",
        "width": 1440,
        "height": 960,
        "minWidth": 980,
        "minHeight": 720,
        "resizable": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": []
  }
}
